<link rel="stylesheet" href="/styles.css">

<h1>{{employee.name}}</h1>
<img src="/employee/{{employee._id}}/photo" alt="employee photo" width="200">
<p>Name: {{employee.name}}</p>
<p>Phone: {{employee.phone}}</p>
<p><a href="/employee/{{employee._id}}/edit">Edit Details</a></p>



<h2>Upload Document</h2>

<form method="post" action="/employee/{{employee._id}}/upload" enctype="multipart/form-data">
  <p>
    PDF File:<br>
    <input type="file" name="document" accept="application/pdf">
  </p>

  <button type="submit">Upload</button>
</form>

<h2>Documents</h2>

<ul>
  {{#each documents}}
    <li>
      <a href="/document/{{this._id}}">{{this.originalName}}</a>
    </li>
  {{/each}}
</ul>




<p>
  <a href="/">Back to list</a>
</p>

<h2>Shifts</h2>

<table border="1" cellpadding="6">
  <tr>
    <th>Date</th>
    <th>Start</th>
    <th>End</th>
  </tr>

  {{#each shifts}}
    <tr>
      <td>{{this.date}}</td>
      <td class="{{this.startClass}}">{{this.startTime}}</td>
      <td>{{this.endTime}}</td>
    </tr>
  {{/each}}
</table>