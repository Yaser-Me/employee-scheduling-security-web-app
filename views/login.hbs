<link rel="stylesheet" href="/styles.css">

<h1>Login</h1>

{{#if message}}
  <p>{{message}}</p>
{{/if}}

<form method="post" action="/login">
  <p>
    Username:<br>
    <input type="text" name="username">
  </p>

  <p>
    Password:<br>
    <input type="password" name="password">
  </p>

  <button type="submit">Login</button>
</form>